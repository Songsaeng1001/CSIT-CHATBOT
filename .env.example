# ═══════════════════════════════════════════════
# น้องซีที — Environment Variables Example
# Copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ═══════════════════════════════════════════════

# ─── LLM Provider ─────────────────────────────
# Google Gemini (แนะนำ — ฟรี)
# สมัครที่: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI (ทางเลือก — จ่ายเงิน)
# OPENAI_API_KEY=sk-...

# ─── LINE Messaging API ───────────────────────
# สร้างที่: https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# ─── App Settings ─────────────────────────────
APP_ENV=development
APP_NAME=nong-csit-chatbot
LOG_LEVEL=INFO
PORT=8000

# ─── Vector Database ──────────────────────────
CHROMA_DIR=./chroma_db
COLLECTION_NAME=csit_knowledge

# ─── SQLite Database ──────────────────────────
SQLITE_PATH=./data/csit.db

# ─── Embedding Model ──────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3

# ─── n8n Webhooks (ตั้งภายหลัง) ────────────────
# N8N_WEBHOOK_LOG=http://localhost:5678/webhook/log-question
# N8N_WEBHOOK_ALERT=http://localhost:5678/webhook/low-confidence